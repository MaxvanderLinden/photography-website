<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="{{ description or site.description }}" />
  <title>{% if title %}{{ title }} — {% endif %}{{ site.name }}</title>
  <link rel="stylesheet" href="/assets/css/style.css" />
</head>
<body>
  {% include "nav.njk" %}
  {{ content | safe }}
  <script>
    function markLoaded(img) {
      img.classList.add("loaded");
    }
    document.querySelectorAll("img").forEach(function (img) {
      if (img.complete && img.naturalWidth > 0) {
        markLoaded(img);
      } else {
        img.addEventListener("load", function () { markLoaded(img); });
        img.addEventListener("error", function () { markLoaded(img); });
      }
    });
  </script>
  <footer class="footer">
    <p>&copy; {{ '' | dateYear }} {{ site.name }}. All rights reserved.
    
    No photography or written content may be reproduced, distributed, or used in any form without explicit written permission from the copyright holder.
</p>
  </footer>
</body>
</html>
