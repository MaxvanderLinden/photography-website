---
layout: base.njk
---
<main class="project">
  <header class="project__header">
    <h1 class="project__title">{{ title }}</h1>
    <p class="project__meta">
      {% if venue %}<span>{{ venue }}</span>{% endif %}
      {% if venue and dates %}<span class="project__meta-sep">&thinsp;—&thinsp;</span>{% endif %}
      {% if dates %}<span>{{ dates }}</span>{% endif %}
    </p>
    {% if address %}
    <p class="project__meta">
      {% if addressUrl %}
      <a href="{{ addressUrl }}" target="_blank" rel="noopener noreferrer">{{ address }}</a>
      {% else %}
      {{ address }}
      {% endif %}
    </p>
    {% endif %}
  </header>

  {% if images %}
  <div class="project__images">
    {% for img in images %}
    <figure class="project__figure">
      <img src="{{ img | url }}" alt="{{ title }}" loading="lazy" decoding="async" />
    </figure>
    {% endfor %}
  </div>
  {% endif %}

  {% if content %}
  <div class="project__description">
    {{ content | safe }}
  </div>
  {% endif %}

  <a href="{{ '/exhibitions/' | url }}" class="project__back">← exhibitions</a>
</main>
